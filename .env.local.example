# Supabase — Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API — Python backend on Railway
NEXT_PUBLIC_API_URL=https://api-service-production-1233.up.railway.app

# Site URL — Used for auth redirects (email confirmation, password reset)
# In production: set this in Vercel → Settings → Environment Variables
# Falls back to NEXT_PUBLIC_VERCEL_URL (auto-injected) → localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp bot phone number (no plus sign, E.164 digits only).
# Used by the signup form to build the ``wa.me/<number>?text=Hola`` deeplink
# when a new user hits the 24h conversation-window-closed screen.
NEXT_PUBLIC_WA_BOT_NUMBER=51942961598

# Sentry — Error tracking + performance monitoring.
# Without these vars, Sentry is disabled (no-op) and the app works normally.
# Set these in Vercel (Preview + Production) once real DSNs are available.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source map upload at build time (optional, build-only, never runtime).
SENTRY_AUTH_TOKEN=
