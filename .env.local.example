# Supabase — Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API — Python backend on Railway
NEXT_PUBLIC_API_URL=https://api-service-production-1233.up.railway.app

# Site URL — Used for auth redirects (email confirmation, password reset)
# In production: set this in Vercel → Settings → Environment Variables
# Falls back to NEXT_PUBLIC_VERCEL_URL (auto-injected) → localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
